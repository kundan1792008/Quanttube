# ---------------------------------------------------------------------------
# Quanttube Environment Variables
# Copy this file to .env and fill in the real values before starting the
# server locally or before deploying.
# ---------------------------------------------------------------------------

# --- Server ---------------------------------------------------------------
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# --- Database (Prisma / PostgreSQL) ---------------------------------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=postgresql://quanttube:changeme@localhost:5432/quanttube_dev

# --- Quantmail Biometric SSO ----------------------------------------------
# Secret used to verify JWT tokens issued by the Quantmail service.
# Must match the signing secret configured in the Quantmail deployment.
QUANTMAIL_JWT_SECRET=your-quantmail-jwt-secret-here
# Issuer claim expected in every Quantmail JWT (default: quantmail)
QUANTMAIL_ISSUER=quantmail
# Optional audience claim expected in Quantmail JWTs
QUANTMAIL_AUDIENCE=quanttube

# --- CDN (HLS Stream delivery) --------------------------------------------
# Base URL where HLS manifests are hosted (e.g. CloudFront / Cloudflare R2)
CDN_BASE_URL=https://cdn.quanttube.app

# --- NextAuth / OAuth (frontend app) ---------------------------------------
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Redis (future: BullMQ job queue, rate limiting) ---------------------
REDIS_URL=redis://localhost:6379

# --- SendGrid / SES (future: creator notifications) ----------------------
SENDGRID_API_KEY=SG.xxxxxxxxxx
